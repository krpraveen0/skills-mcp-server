# ── Server ────────────────────────────────────────────
PORT=8080
ENV=development                    # development | production

# ── Database ──────────────────────────────────────────
SQLITE_PATH=./data/skills.db

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                    # Optional Redis password

# ── GitHub ────────────────────────────────────────────
# Without a token: 60 requests/hour (may be enough for dev)
# With a token: 5000 requests/hour
GITHUB_TOKEN=ghp_your_token_here

# ── Auth ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=sk_live_your_admin_key_here
API_KEY_SALT=your_random_salt_here_change_this

# ── Cache TTLs (seconds) ──────────────────────────────
CACHE_TTL_SEARCH=3600              # 1 hour
CACHE_TTL_TRENDING=86400           # 24 hours
CACHE_TTL_SKILL=3600               # 1 hour

# ── Crawler ───────────────────────────────────────────
CRAWL_SCHEDULE=0 2 * * *          # Every day at 2am
CRAWL_MAX_RESULTS=1000
